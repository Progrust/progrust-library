    "js-yaml": "^5.2.1",
    "mermaid-isomorphic": "^3.1.0",
    "playwright": "^1.61.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.1",
    "eslint": "^10.6.0",
    "eslint-plugin-astro": "^2.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "shiki": "^4.3.1",
    "tailwindcss": "^4.3.2",
