  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "dev:clean": "astro dev --force",
    "stop": "astro dev stop",
    "build": "astro build",
    "preview": "astro preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "astro check",
    "test": "vitest run",
    "check:dict": "node scripts/check-dict-code.mjs",
    "dict:todo": "node scripts/list-dict-todo.mjs",
