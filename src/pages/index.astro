---
// トップページ（pages.md R-5〜R-7 / AC-2）。確定モック top-b-sharp を視覚の正とする。
// ヘッダー/フッターは BaseLayout が供給するため、ここでは <main> のみを実装する。
import BaseLayout from "../layouts/BaseLayout.astro";
import KindBadge from "../components/KindBadge.astro";
import { SITE, SITE_LINKS } from "../lib/site";
import {
  getPublicDict,
  getPublicArticles,
  getPublicBooks,
  getPublicChapters,
  mergeRecent,
  type ContentKind,
} from "../lib/content";

const [dict, articles, books, chapters] = await Promise.all([
  getPublicDict(),
  getPublicArticles(),
  getPublicBooks(),
  getPublicChapters(),
]);

// 新着（3タイプ混在・created_at 降順・最大10件・章除外。pages R-5/AC-2）
const recent = mergeRecent(dict, articles, books, 10);

// タグ件数は本・章も対象（tags 一覧 pages R-18/R-19 と揃える。集計はトップ限定なのでインライン）
const tagCount = new Set(
  [...dict, ...articles, ...books, ...chapters].flatMap((e) => e.data.tags),
).size;

// 種別 → 詳細ページの URL 接頭辞（辞書/記事/本。id はコレクションの generateId 由来）
const DETAIL_BASE: Record<ContentKind, string> = {
  dict: "/dict/",
  article: "/articles/",
  book: "/books/",
};

// 一覧への導線（pages R-6）。number は連番表示、count は算出件数
const collections = [
  {
    href: "/dict/",
    number: "01",
    en: "DICTIONARY",
    label: "辞書",
    count: dict.length,
  },
  {
    href: "/articles/",
    number: "02",
    en: "ARTICLES",
    label: "記事",
    count: articles.length,
  },
  {
    href: "/books/",
    number: "03",
    en: "BOOKS",
    label: "本",
    count: books.length,
  },
  { href: "/tags/", number: "04", en: "TAGS", label: "タグ", count: tagCount },
];

// 「このサイトについて」の3形式カード（辞書・記事・本）
const formats = [
  {
    kind: "dict" as const,
    number: "01 / DICTIONARY",
    title: "単語を引くように",
    body: "所有権・ライフタイムなど、1つの用語を短くまとめたページ。記事や本の中からリンクで参照されます。",
  },
  {
    kind: "article" as const,
    number: "02 / ARTICLES",
    title: "1つのテーマを1ページで",
    body: "特定のテーマを掘り下げる技術ブログ形式のページ。手を動かした記録や考察を残します。",
  },
  {
    kind: "book" as const,
    number: "03 / BOOKS",
    title: "体系立てて章で読む",
    body: "複数の章で構成されたまとまったコンテンツ。入門から実践まで、順を追って読める形にまとめます。",
  },
];
---

<BaseLayout title={SITE.title}>
  <main class="mx-auto max-w-6xl px-4 sm:px-8">
    {/* ヒーロー（pages R-7: SNS/GitHub アイコンのみ） */}
    <section class="border-b border-line py-14 sm:py-20">
      <p class="mb-4 font-mono text-xs text-accent">// programming in rust</p>
      <h1
        class="mb-6 font-display text-5xl font-black leading-none tracking-tighter text-strong sm:text-7xl"
      >
        Progrust<br />Library<span class="text-accent">.</span>
      </h1>
      <p class="max-w-lg text-sm leading-relaxed text-sub sm:text-base">
        Rustで学んだことを「辞書」「記事」「本」の3つの形式で蔵書していく、個人の技術ライブラリ。
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a
          href={SITE_LINKS.github}
          aria-label="GitHub"
          class="grid h-10 w-10 place-items-center rounded border border-line bg-card text-sub transition-colors hover:border-accent hover:text-accent motion-reduce:transition-none"
        >
          <svg
            width="17"
            height="17"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.47-1.11-1.47-.9-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.89 1.52 2.34 1.08 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.02a9.56 9.56 0 0 1 5 0c1.91-1.3 2.75-1.02 2.75-1.02.55 1.37.2 2.39.1 2.64.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.68-4.57 4.93.36.31.68.92.68 1.85V21c0 .27.18.58.69.48A10 10 0 0 0 12 2Z"
            ></path>
          </svg>
        </a>
        <a
          href={SITE_LINKS.x}
          aria-label="X"
          class="grid h-10 w-10 place-items-center rounded border border-line bg-card text-sub transition-colors hover:border-accent hover:text-accent motion-reduce:transition-none"
        >
          <svg
            width="15"
            height="15"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M18.2 2h3.3l-7.3 8.4L22.8 22h-6.7l-5.3-6.9L4.7 22H1.4l7.8-9L1.2 2h6.9l4.8 6.3L18.2 2Zm-1.2 18h1.9L6.9 3.9H4.9L17 20Z"
            ></path>
          </svg>
        </a>
        <a
          href={SITE_LINKS.rss}
          aria-label="RSS"
          class="grid h-10 w-10 place-items-center rounded border border-line bg-card text-sub transition-colors hover:border-accent hover:text-accent motion-reduce:transition-none"
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M4 4a16 16 0 0 1 16 16h-3A13 13 0 0 0 4 7V4Zm0 6a10 10 0 0 1 10 10h-3a7 7 0 0 0-7-7v-3Zm2.5 6.5A1.5 1.5 0 1 1 5 18a1.5 1.5 0 0 1 1.5-1.5Z"
            ></path>
          </svg>
        </a>
      </div>
    </section>

    {/* コレクション（pages R-6: 各一覧への導線） */}
    <section
      aria-label="コンテンツ一覧"
      class="grid grid-cols-2 border-b border-line lg:grid-cols-4"
    >
      {
        collections.map((c, i) => (
          <a
            href={c.href}
            class:list={[
              "group border-line px-1 py-6 transition hover:bg-card motion-reduce:transition-none sm:px-4",
              // 2列/4列どちらでも列間だけに縦罫線が出るようにする（モック top-b-sharp 準拠）。
              // 辞書・本は常時右罫線、記事は 4 列（lg）時のみ右罫線、タグは罫線なし。
              (i === 0 || i === 2) && "border-r",
              i === 1 && "lg:border-r",
            ]}
          >
            <p class="mb-1 font-mono text-[11px] text-sub">
              {c.number} / {c.en}
            </p>
            <p class="font-display text-lg font-bold text-strong group-hover:text-accent">
              {c.label}{" "}
              <span class="font-mono text-xs text-sub">{c.count}</span>
            </p>
          </a>
        ))
      }
    </section>

    {/* 新着（pages R-5/AC-2: 台帳リスト行・3タイプ混在・降順10件・章除外） */}
    <section class="py-12 sm:py-16">
      <p class="mb-4 font-mono text-xs text-accent">// new</p>
      <div class="mb-8 flex items-baseline justify-between">
        <h2
          class="font-display text-2xl font-black tracking-tight text-strong sm:text-3xl"
        >
          新着
        </h2>
        <p class="font-mono text-xs text-sub">RECENT 10 / created_at desc</p>
      </div>
      <ol class="border-t border-line">
        {
          recent.map((e) => (
            <li>
              <a
                href={`${DETAIL_BASE[e.kind]}${e.id}`}
                class="group grid grid-cols-[auto_auto_1fr] items-center gap-x-4 border-b border-line py-4 transition hover:bg-card motion-reduce:transition-none sm:grid-cols-[7rem_4.5rem_1fr_auto]"
              >
                <time
                  datetime={e.data.created_at.toISOString().slice(0, 10)}
                  class="font-mono text-xs text-sub"
                >
                  {e.data.created_at.toISOString().slice(0, 10)}
                </time>
                <KindBadge kind={e.kind} class="justify-self-start" />
                <span class="col-span-3 mt-1 min-w-0 truncate font-display font-bold text-strong group-hover:text-accent sm:col-span-1 sm:mt-0">
                  {e.data.title}
                </span>
                <span class="hidden gap-2 font-mono text-[11px] text-sub sm:flex">
                  {e.data.tags.slice(0, 2).map((tag) => (
                    <span>#{tag}</span>
                  ))}
                </span>
              </a>
            </li>
          ))
        }
      </ol>
    </section>

    {
      /* このサイトについて（pages R-25: ページ最下部にサイト紹介 + 3形式カード） */
    }
    <section class="py-12 sm:py-16">
      <p class="mb-4 font-mono text-xs text-accent">// about this site</p>
      <h2
        class="mb-6 font-display text-2xl font-black tracking-tight text-strong sm:text-3xl"
      >
        このサイトについて<span class="text-accent">.</span>
      </h2>
      <div
        class="mb-10 max-w-2xl space-y-3 text-sm leading-relaxed sm:text-base"
      >
        <p>
          Progrust
          Libraryは、Rustプログラミング言語に関する内容を細かく分割して「辞書」として記載しています。各ページではこの「辞書」の中身を簡単に確認できるようにしており、わからない固有名詞が登場しても記事を読む手を止めることなく読み進められるようにしています。
        </p>
        <p class="text-sub">
          コンテンツは粒度に応じて次の3つの形式に分けて整理しています。
        </p>
      </div>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
        {
          formats.map((f) => (
            <div class="flex flex-col gap-3 rounded border border-line bg-card p-5">
              <div class="flex items-center justify-between">
                <KindBadge kind={f.kind} />
                <span class="font-mono text-[11px] text-sub">{f.number}</span>
              </div>
              <p class="font-display font-bold text-strong">{f.title}</p>
              <p class="text-sm leading-relaxed text-sub">{f.body}</p>
            </div>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
