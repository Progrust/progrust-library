---
// 暫定トップページ。BaseLayout（ヘッダー/フッター/テーマ切替）の土台が全ページで
// 機能することを実ページで確認するためのプレースホルダ。
// 正式なトップページ（新着一覧等）は T3-2 で差し替える。
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../lib/site";
---

<BaseLayout title={SITE.title}>
  <main class="mx-auto max-w-6xl px-4 py-10 sm:px-8">
    <h1 class="font-display text-2xl font-bold text-strong">
      Progrust Library<span class="text-accent">.</span>
    </h1>
    <p class="mt-4 text-sub">
      レイアウト構築中（T3-1）。正式なトップページは T3-2 で実装する。
    </p>
  </main>
</BaseLayout>
