---
// T1-3 確認用の仮ページ。コレクション経由で本文を render() し、
// wikilink が `<a href="/dict/[slug]" class="wikilink">タイトル</a>` に
// 変換されることをビルド成果物（dist）で確認する。
// ※P3 で本番ルーティングを入れる際にこのページは撤去する。
import { render } from "astro:content";
import "../styles/global.css";
import {
  getPublicDict,
  getPublicArticles,
  getPublicBooks,
} from "../lib/content";

// wikilink を含む代表エントリ（辞書・記事・本index）を種別横断でレンダリングする。
// markdown-notation-test は rule.md 全記法の恒常検証用（T2-5）。
const targetIds = new Set([
  "ownership",
  "rc",
  "rust-ownership-deep-dive",
  "markdown-notation-test",
]);
const entries = [
  ...(await getPublicDict()),
  ...(await getPublicArticles()),
  ...(await getPublicBooks()),
].filter(
  (entry) => targetIds.has(entry.id) || entry.id === "rust-web-app-book",
);

const rendered = await Promise.all(
  entries.map(async (entry) => ({
    entry,
    Content: (await render(entry)).Content,
  })),
);
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>debug: rendered bodies (T1-3)</title>
  </head>
  <body class="min-h-screen bg-white p-8 text-gray-900">
    <main class="mx-auto max-w-3xl space-y-12">
      <h1 class="text-2xl font-bold">
        Rendered bodies（T1-3 確認用・P3で撤去）
      </h1>
      {
        rendered.map(({ entry, Content }) => (
          <section class="border-t pt-8">
            <h2 class="text-xl font-semibold">
              {entry.data.title}（<code>{entry.id}</code>）
            </h2>
            <div class="prose mt-4">
              <Content />
            </div>
          </section>
        ))
      }
    </main>
  </body>
</html>
