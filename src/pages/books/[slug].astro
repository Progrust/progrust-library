---
// 本トップ（pages R-1/R-17, AC-5 / ui-design-spec §301〜307）。
// 章目次サイドバー型。左=章目次（本番は公開章のみ=pages AC-5）/ 右=ヒーロー+本文。
// getStaticPaths は getPublicBooks 経由で全公開本を列挙する（architecture §5）。
import { render } from "astro:content";
import {
  getPublicBooks,
  getPublicChapters,
  sortChapters,
  chapterLedger,
} from "../../lib/content";
import {
  buildContentWikilinkGraph,
  forwardKey,
} from "../../lib/wikilink-graph";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ChapterToc from "../../components/ChapterToc.astro";
import LinkedDictList from "../../components/LinkedDictList.astro";

export async function getStaticPaths() {
  const [books, chapters, graph] = await Promise.all([
    getPublicBooks(),
    getPublicChapters(),
    buildContentWikilinkGraph(),
  ]);
  return books.map((book) => {
    // 本 slug 配下の章を連番昇順で台帳化。getPublicChapters は本番で公開章のみ（pages AC-5）。
    const bookChapters = sortChapters(
      chapters.filter((chapter) => chapter.id.startsWith(`${book.id}/`)),
    );
    const ledger = chapterLedger(bookChapters, book.id);
    return {
      params: { slug: book.id },
      props: {
        book,
        ledger,
        linkedDicts: graph.forward.get(forwardKey("book", book.id)) ?? [],
      },
    };
  });
}

const { book, ledger, linkedDicts } = Astro.props;
const { Content } = await render(book);
const createdIso = book.data.created_at.toISOString().slice(0, 10);
const updatedIso = book.data.updated_at.toISOString().slice(0, 10);
---

<BaseLayout
  title={book.data.title}
  description={book.data.description}
  ogType="article"
>
  <main class="mx-auto max-w-5xl px-4 py-10 sm:px-8">
    <div class="lg:grid lg:grid-cols-[15rem_minmax(0,1fr)] lg:gap-12">
      {/* 左: 章目次サイドバー（lg 以上・sticky） */}
      <aside class="hidden lg:block">
        <ChapterToc
          bookTitle={book.data.title}
          bookHref={`/books/${book.id}`}
          chapters={ledger}
          class="sticky top-24"
        />
      </aside>

      {/* 右: ヒーロー + 本文（本文列は max-w-3xl） */}
      <div class="min-w-0 max-w-3xl">
        <header class="mb-10 border-b border-line pb-8">
          <p class="mb-4 font-mono text-xs text-accent">// book</p>
          <div class="grid gap-6 sm:grid-cols-[11rem_1fr] sm:gap-8">
            <img
              src={book.data.image.url}
              alt={book.data.image.alt}
              class="aspect-[600/850] w-40 rounded border border-line object-cover sm:w-full"
            />
            <div>
              <h1
                class="font-display text-3xl font-black leading-tight tracking-tight text-strong sm:text-4xl"
              >
                {book.data.title}<span class="text-accent">.</span>
              </h1>
              <p class="mt-3 text-sm leading-relaxed text-sub">
                {book.data.description}
              </p>
              {
                book.data.tags.length > 0 && (
                  <ul class="mt-4 flex flex-wrap gap-2">
                    {book.data.tags.map((tag) => (
                      <li>
                        <a
                          href={`/tags/${encodeURIComponent(tag)}`}
                          class="font-mono text-[11px] text-sub transition-colors hover:text-accent motion-reduce:transition-none"
                        >
                          #{tag}
                        </a>
                      </li>
                    ))}
                  </ul>
                )
              }
              <div
                class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2 font-mono text-xs text-sub"
              >
                <time datetime={createdIso}>created: {createdIso}</time>
                <time datetime={updatedIso}>updated: {updatedIso}</time>
              </div>
            </div>
          </div>
        </header>

        <div class="prose">
          <Content />
        </div>

        {
          /* 使用辞書一覧（wikilink-ui R-17。本トップは右レールが無いため本文下部に置く・全ブレークポイント） */
        }
        <LinkedDictList
          dicts={linkedDicts}
          class="mt-12 border-t border-line pt-8"
        />

        {/* モバイル: 本文後に章目次セクション（lg 未満・§307） */}
        <section class="mt-12 border-t border-line pt-8 lg:hidden">
          <ChapterToc
            bookTitle={book.data.title}
            bookHref={`/books/${book.id}`}
            chapters={ledger}
            label="目次"
          />
        </section>
      </div>
    </div>
  </main>
</BaseLayout>
