---
// T1-2 確認用の仮ページ。4コレクションの ID・導出URL・章順を列挙し、
// AC-3（辞書 ID = ファイル名）・AC-4（章 URL = 連番除去 + 章順）と、
// chapters に index.md が幽霊混入していない（= 3件）ことを目視で確認する。
// 唯一の非テスト経路である getPublic* ラッパをビルド時に実行する目的も兼ねる。
// ※P3 で本番ルーティングを入れる際にこのページは撤去する。
import "../styles/global.css";
import {
  getPublicDict,
  getPublicArticles,
  getPublicBooks,
  getPublicChapters,
  sortChapters,
} from "../lib/content";

const dict = await getPublicDict();
const articles = await getPublicArticles();
const books = await getPublicBooks();
// AC-4 の章順（連番昇順）を確認できるよう並べ替えて表示する。
const chapters = sortChapters(await getPublicChapters());
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>debug: collection entries (T1-2)</title>
  </head>
  <body class="min-h-screen bg-white p-8 text-gray-900">
    <main class="mx-auto max-w-3xl space-y-8">
      <h1 class="text-2xl font-bold">
        Collection entries（T1-2 確認用・P3で撤去）
      </h1>

      <section>
        <h2 class="text-xl font-semibold">
          dict（{dict.length}件）→ /dict/[id]
        </h2>
        <ul class="mt-2 list-disc pl-6">
          {
            dict.map((e) => (
              <li>
                <code>{e.id}</code> → /dict/{e.id}
                {!e.isPublic && <span class="ml-2 text-red-600">[非公開]</span>}
              </li>
            ))
          }
        </ul>
      </section>

      <section>
        <h2 class="text-xl font-semibold">
          articles（{articles.length}件）→ /articles/[id]
        </h2>
        <ul class="mt-2 list-disc pl-6">
          {
            articles.map((e) => (
              <li>
                <code>{e.id}</code> → /articles/{e.id}
                {!e.isPublic && <span class="ml-2 text-red-600">[非公開]</span>}
              </li>
            ))
          }
        </ul>
      </section>

      <section>
        <h2 class="text-xl font-semibold">
          books（{books.length}件）→ /books/[id]
        </h2>
        <ul class="mt-2 list-disc pl-6">
          {
            books.map((e) => (
              <li>
                <code>{e.id}</code> → /books/{e.id}
                {!e.isPublic && <span class="ml-2 text-red-600">[非公開]</span>}
              </li>
            ))
          }
        </ul>
      </section>

      <section>
        <h2 class="text-xl font-semibold">
          chapters（{chapters.length}件・index混入なら幽霊）→
          /books/[book]/[slug]
        </h2>
        <ul class="mt-2 list-disc pl-6">
          {
            chapters.map((e) => (
              <li>
                <code>{e.id}</code> → /books/{e.id}
                {e.filePath && (
                  <span class="ml-2 text-gray-500">（src: {e.filePath}）</span>
                )}
                {!e.isPublic && <span class="ml-2 text-red-600">[非公開]</span>}
              </li>
            ))
          }
        </ul>
      </section>
    </main>
  </body>
</html>
