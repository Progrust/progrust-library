---
// 辞書詳細（pages R-1/R-12/R-13, AC-7）。dict-detail モックを視覚の正とする。
// getStaticPaths は公開フィルタ（getPublicDict）経由で全公開辞書を列挙する（architecture §5）。
// 逆リンク一覧（R-18）・使用辞書一覧（R-17）は wikilink グラフから算出する（T4-4）。
import { render } from "astro:content";
import { getPublicDict } from "../../lib/content";
import { buildContentWikilinkGraph } from "../../lib/wikilink-graph";
import DetailLayout from "../../layouts/DetailLayout.astro";
import Backlinks from "../../components/Backlinks.astro";

export async function getStaticPaths() {
  const [dict, graph] = await Promise.all([
    getPublicDict(),
    buildContentWikilinkGraph(),
  ]);
  return dict.map((entry) => ({
    params: { slug: entry.id },
    props: {
      entry,
      linkedDicts: graph.forward.get(entry.id) ?? [],
      backlinks: graph.backward.get(entry.id) ?? [],
    },
  }));
}

const { entry, linkedDicts, backlinks } = Astro.props;
const { Content, headings } = await render(entry);
---

<DetailLayout
  title={entry.data.title}
  description={entry.data.description}
  eyebrow="dictionary"
  tags={entry.data.tags}
  updatedAt={entry.data.updated_at}
  headings={headings}
  linkedDicts={linkedDicts}
>
  <Content />
  <Backlinks slot="below" items={backlinks} />
</DetailLayout>
