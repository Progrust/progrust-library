---
// 辞書詳細（pages R-1/R-12/R-13, AC-7）。dict-detail モックを視覚の正とする。
// getStaticPaths は公開フィルタ（getPublicDict）経由で全公開辞書を列挙する（architecture §5）。
// 逆リンク一覧（R-15）・辞書ペイン/使用辞書一覧の動作は P4。
import { render } from "astro:content";
import { getPublicDict } from "../../lib/content";
import DetailLayout from "../../layouts/DetailLayout.astro";

export async function getStaticPaths() {
  const dict = await getPublicDict();
  return dict.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
---

<DetailLayout
  title={entry.data.title}
  description={entry.data.description}
  eyebrow="dictionary"
  tags={entry.data.tags}
  updatedAt={entry.data.updated_at}
  headings={headings}
>
  <Content />
</DetailLayout>
