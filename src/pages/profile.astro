---
// プロフィール（pages.md R-20 / AC-1）。確定モック profile.html を忠実に転記（直書き）。
// ヘッダー/フッターは BaseLayout が供給するため <main> のみ。自己紹介はモックのダミー
// テキストのまま（実文はユーザーが後日差し替える）。3形式カードの種別バッジは KindBadge を再利用。
import BaseLayout from "../layouts/BaseLayout.astro";
import KindBadge from "../components/KindBadge.astro";
import { SITE_LINKS } from "../lib/site";

// 「このサイトについて」の3形式カード（辞書・記事・本）
const formats = [
  {
    kind: "dict" as const,
    number: "01 / DICTIONARY",
    title: "単語を引くように",
    body: "所有権・ライフタイムなど、1つの用語を短くまとめたページ。記事や本の中からリンクで参照されます。",
  },
  {
    kind: "article" as const,
    number: "02 / ARTICLES",
    title: "1つのテーマを1ページで",
    body: "特定のテーマを掘り下げる技術ブログ形式のページ。手を動かした記録や考察を残します。",
  },
  {
    kind: "book" as const,
    number: "03 / BOOKS",
    title: "体系立てて章で読む",
    body: "複数の章で構成されたまとまったコンテンツ。入門から実践まで、順を追って読める形にまとめます。",
  },
];

// SNS / 外部リンク（プロフィールでは ラベル付きボタン型）
const socials = [
  {
    href: SITE_LINKS.github,
    label: "GitHub",
    size: 16,
    path: "M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.47-1.11-1.47-.9-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.89 1.52 2.34 1.08 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.02a9.56 9.56 0 0 1 5 0c1.91-1.3 2.75-1.02 2.75-1.02.55 1.37.2 2.39.1 2.64.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.68-4.57 4.93.36.31.68.92.68 1.85V21c0 .27.18.58.69.48A10 10 0 0 0 12 2Z",
  },
  {
    href: SITE_LINKS.x,
    label: "X",
    size: 14,
    path: "M18.2 2h3.3l-7.3 8.4L22.8 22h-6.7l-5.3-6.9L4.7 22H1.4l7.8-9L1.2 2h6.9l4.8 6.3L18.2 2Zm-1.2 18h1.9L6.9 3.9H4.9L17 20Z",
  },
  {
    href: SITE_LINKS.rss,
    label: "RSS",
    size: 15,
    path: "M4 4a16 16 0 0 1 16 16h-3A13 13 0 0 0 4 7V4Zm0 6a10 10 0 0 1 10 10h-3a7 7 0 0 0-7-7v-3Zm2.5 6.5A1.5 1.5 0 1 1 5 18a1.5 1.5 0 0 1 1.5-1.5Z",
  },
];
---

<BaseLayout title="プロフィール">
  <main class="mx-auto max-w-6xl px-4 sm:px-8">
    {/* プロフィール */}
    <section class="border-b border-line py-14 sm:py-20">
      <p class="mb-8 font-mono text-xs text-accent">// profile</p>
      <div class="flex flex-col gap-8 sm:flex-row sm:items-start sm:gap-12">
        <div class="min-w-0">
          <h1
            class="mb-2 font-display text-4xl font-black leading-none tracking-tighter text-strong sm:text-5xl"
          >
            nishiki<span class="text-accent">.</span>
          </h1>
          <p class="mb-6 font-mono text-xs text-sub">
            Rust learner / software engineer
          </p>
          <div class="max-w-xl space-y-3 text-sm leading-relaxed sm:text-base">
            <p>
              Rustを学びながら、学んだことをこのライブラリに蔵書しているソフトウェアエンジニアです。普段は業務でWebアプリケーションの開発をしています。（ダミーテキスト）
            </p>
            <p class="text-sub">
              好きなものは所有権システムと静的型付け。最近はAxumでのWeb
              API開発と、非同期ランタイムの中身を追いかけることに時間を溶かしています。（ダミーテキスト）
            </p>
          </div>
          {/* SNS / 外部リンク */}
          <div class="mt-8 flex flex-wrap items-center gap-3">
            {
              socials.map((s) => (
                <a
                  href={s.href}
                  class="group inline-flex h-10 items-center gap-2.5 rounded border border-line bg-card px-4 font-display text-sm font-bold text-strong transition-colors hover:border-accent hover:text-accent motion-reduce:transition-none"
                >
                  <svg
                    width={s.size}
                    height={s.size}
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                    class="text-sub transition-colors group-hover:text-accent motion-reduce:transition-none"
                  >
                    <path d={s.path} />
                  </svg>
                  {s.label}
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    {/* このサイトについて */}
    <section class="py-12 sm:py-16">
      <p class="mb-4 font-mono text-xs text-accent">// about this site</p>
      <h2
        class="mb-6 font-display text-2xl font-black tracking-tight text-strong sm:text-3xl"
      >
        このサイトについて<span class="text-accent">.</span>
      </h2>
      <div
        class="mb-10 max-w-2xl space-y-3 text-sm leading-relaxed sm:text-base"
      >
        <p>
          Progrust
          Libraryは、Rustプログラミングについて学んだことを「蔵書」していく個人の技術ライブラリです。読んで終わりではなく、あとから引いて使える形で残すことを目指しています。（ダミーテキスト）
        </p>
        <p class="text-sub">
          コンテンツは粒度に応じて次の3つの形式に分けて整理しています。（ダミーテキスト）
        </p>
      </div>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
        {
          formats.map((f) => (
            <div class="flex flex-col gap-3 rounded border border-line bg-card p-5">
              <div class="flex items-center justify-between">
                <KindBadge kind={f.kind} />
                <span class="font-mono text-[11px] text-sub">{f.number}</span>
              </div>
              <p class="font-display font-bold text-strong">{f.title}</p>
              <p class="text-sm leading-relaxed text-sub">{f.body}</p>
            </div>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
