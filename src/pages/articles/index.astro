---
// 記事一覧（pages R-9/R-11 / AC-3）。概要 + ヘッダ画像の横並びカードを縦スタック。
// 絞込 UI は静的配置（動作は P5）。全件表示・ページ送りなし。
import BaseLayout from "../../layouts/BaseLayout.astro";
import EntryCard from "../../components/EntryCard.astro";
import ListFilter from "../../components/ListFilter.astro";
import { getPublicArticles, tagCounts } from "../../lib/content";

// getPublicArticles は新着順ソート済み（pages R-4）
const articles = await getPublicArticles();
const tags = tagCounts(articles);
---

<BaseLayout title="記事一覧">
  <main class="mx-auto max-w-6xl px-4 sm:px-8 py-12 sm:py-16">
    <section class="mb-8">
      <p class="mb-3 font-mono text-xs text-accent">// articles</p>
      <div class="flex flex-wrap items-baseline gap-x-4">
        <h1
          class="font-display text-4xl font-black leading-none tracking-tighter text-strong sm:text-5xl"
        >
          記事<span class="text-accent">.</span>
        </h1>
        <p class="font-mono text-xs text-sub">
          {articles.length} entries / created_at desc
        </p>
      </div>
      <p class="mt-4 max-w-lg text-sm leading-relaxed text-sub">
        Rustで学んだことを1ページにまとめた技術記事。
      </p>
    </section>

    <ListFilter tags={tags} total={articles.length} />

    <div class="flex flex-col gap-4">
      {
        articles.map((entry) => (
          <EntryCard
            href={`/articles/${entry.id}`}
            title={entry.data.title}
            description={entry.data.description}
            createdAt={entry.data.created_at}
            tags={entry.data.tags}
            image={entry.data.image}
          />
        ))
      }
    </div>
  </main>
</BaseLayout>
