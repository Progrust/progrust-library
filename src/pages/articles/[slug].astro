---
// 記事詳細（pages R-1/R-12/R-13, AC-7）。詳細レイアウトは辞書と共用（DetailLayout）。
// getStaticPaths は公開フィルタ（getPublicArticles・新着順ソート済み）経由で列挙する。
// ヘッダ画像は詳細ページには表示しない（R-12 が規定するのはタイトル/タグ/更新日/本文のみ）。
import { render } from "astro:content";
import { getPublicArticles } from "../../lib/content";
import DetailLayout from "../../layouts/DetailLayout.astro";

export async function getStaticPaths() {
  const articles = await getPublicArticles();
  return articles.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
---

<DetailLayout
  title={entry.data.title}
  description={entry.data.description}
  eyebrow="article"
  tags={entry.data.tags}
  updatedAt={entry.data.updated_at}
  headings={headings}
>
  <Content />
</DetailLayout>
