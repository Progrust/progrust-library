---
// 詳細ページ共通レイアウト（architecture.md §6 / ui-design-spec「レイアウト」）。
// 3カラムグリッド（左=目次 / 中央=タイトル・タグ・更新日・本文 / 右=辞書ペイン）。
// 辞書・記事・章・本トップで共用する想定。本タスク（T3-4）では辞書・記事のみ配線する。
// タイトルは frontmatter の title を正とする（markdown-notation/rule.md: 本文で h1 は基本使わない）。
import type { MarkdownHeading } from "astro";
import BaseLayout from "./BaseLayout.astro";
import Toc from "../components/Toc.astro";
import DictPane from "../components/DictPane.astro";
import MobileNav from "../components/MobileNav.astro";

interface Props {
  title: string;
  description?: string;
  /** eyebrow のテキスト（例: "dictionary" → // dictionary） */
  eyebrow?: string;
  tags: string[];
  updatedAt: Date;
  headings: MarkdownHeading[];
}

const { title, description, eyebrow, tags, updatedAt, headings } = Astro.props;
const updatedIso = updatedAt.toISOString().slice(0, 10);
---

<BaseLayout title={title} description={description}>
  <main class="mx-auto max-w-7xl px-4 py-10 sm:px-8">
    <div class="lg:grid lg:grid-cols-[200px_minmax(0,1fr)_320px] lg:gap-10">
      {/* 左: 目次（lg 以上・sticky） */}
      <aside class="hidden lg:block">
        <Toc headings={headings} class="sticky top-24" />
      </aside>

      {/* 中央: タイトル / タグ一覧 / 更新日 / 本文（pages R-12） */}
      <article class="mx-auto min-w-0 max-w-2xl lg:max-w-none">
        <header class="mb-8 border-b border-line pb-6">
          {
            eyebrow && (
              <p class="mb-3 font-mono text-xs text-accent">// {eyebrow}</p>
            )
          }
          <h1
            class="font-display text-3xl font-black leading-tight tracking-tight text-strong sm:text-4xl"
          >
            {title}<span class="text-accent">.</span>
          </h1>
          <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2">
            {
              tags.length > 0 && (
                <ul class="flex flex-wrap gap-2">
                  {tags.map((tag) => (
                    <li>
                      <a
                        href={`/tags/${encodeURIComponent(tag)}`}
                        class="font-mono text-[11px] text-sub transition-colors hover:text-accent motion-reduce:transition-none"
                      >
                        #{tag}
                      </a>
                    </li>
                  ))}
                </ul>
              )
            }
            <time datetime={updatedIso} class="font-mono text-xs text-sub"
              >updated: {updatedIso}</time
            >
          </div>
        </header>

        <div class="prose">
          <slot />
        </div>

        {/* 逆リンク（辞書・R-15）= P4 / 前後章ナビ（R-16）= T3-5 の差込口 */}
        <slot name="below" />
      </article>

      {/* 右: 辞書ペイン（枠のみ・動作は P4）。使用辞書一覧も P4。 */}
      <aside class="hidden lg:block">
        <div class="sticky top-24">
          <DictPane />
        </div>
      </aside>
    </div>
  </main>

  {/* モバイル: フローティング目次ボタン + 目次ボトムシート */}
  <MobileNav headings={headings} />

  <script>
    import { initToc } from "../scripts/toc";
    initToc();
  </script>
</BaseLayout>
