---
// 詳細ページ共通レイアウト（architecture.md §6 / ui-design-spec「レイアウト」）。
// 3カラムグリッド（左=目次 / 中央=タイトル・タグ・更新日・本文 / 右=辞書ペイン）。
// 辞書・記事・章・本トップで共用する想定。本タスク（T3-4）では辞書・記事のみ配線する。
// タイトルは frontmatter の title を正とする（markdown-notation/rule.md: 本文で h1 は基本使わない）。
import type { MarkdownHeading } from "astro";
import type { DictTarget } from "../lib/wikilink-graph";
import { tocHeadings } from "../lib/content";
import BaseLayout from "./BaseLayout.astro";
import Toc from "../components/Toc.astro";
import DictPane from "../components/DictPane.astro";
import LinkedDictList from "../components/LinkedDictList.astro";
import MobileNav from "../components/MobileNav.astro";

interface Props {
  title: string;
  description?: string;
  /** eyebrow のテキスト（例: "dictionary" → // dictionary） */
  eyebrow?: string;
  tags: string[];
  updatedAt: Date;
  headings: MarkdownHeading[];
  /** 使用辞書一覧（本文がリンクしている辞書。wikilink-ui R-17）。ページ側で wikilink グラフから算出 */
  linkedDicts?: DictTarget[];
}

const {
  title,
  description,
  eyebrow,
  tags,
  updatedAt,
  headings,
  linkedDicts = [],
} = Astro.props;
const updatedIso = updatedAt.toISOString().slice(0, 10);
// 目次対象見出しが無いページは左カラム（240px）を省略して2カラムにする
// （Toc.astro の表示条件と同じ tocHeadings で判定。ui-design-spec「レイアウト」）
const hasToc = tocHeadings(headings).length > 0;
const gridCols = hasToc
  ? "lg:grid-cols-[240px_minmax(0,1fr)_384px]"
  : "lg:grid-cols-[minmax(0,1fr)_384px]";
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  maxWidthClass="max-w-[96rem]"
>
  <main class="mx-auto max-w-[96rem] px-4 py-10 sm:px-8">
    <div class={`lg:grid lg:gap-10 ${gridCols}`}>
      {/* 左: 目次（lg 以上・sticky）。目次が無いページではカラムごと省略 */}
      {
        hasToc && (
          <aside class="hidden lg:block">
            <Toc headings={headings} class="sticky top-24" />
          </aside>
        )
      }

      {/* 中央: タイトル / タグ一覧 / 更新日 / 本文（pages R-12） */}
      {
        /* lg 以上（グリッド時）は mx-auto を切る: グリッドアイテムに auto マージンが
          付くと stretch が効かず fit-content 幅に縮むため（lg 未満の中央寄せ用にのみ残す） */
      }
      <article class="mx-auto min-w-0 max-w-2xl lg:mx-0 lg:max-w-none">
        <header class="mb-8 border-b border-line pb-6">
          {
            eyebrow && (
              <p class="mb-3 font-mono text-xs text-accent">// {eyebrow}</p>
            )
          }
          <h1
            class="font-display text-3xl font-black leading-tight tracking-tight text-strong sm:text-4xl"
          >
            {title}<span class="text-accent">.</span>
          </h1>
          <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2">
            {
              tags.length > 0 && (
                <ul class="flex flex-wrap gap-2">
                  {tags.map((tag) => (
                    <li>
                      <a
                        href={`/tags/${encodeURIComponent(tag)}`}
                        class="rounded border border-line bg-card px-2.5 py-1 font-mono text-[11px] text-sub transition-colors hover:border-accent hover:text-accent motion-reduce:transition-none"
                      >
                        #{tag}
                      </a>
                    </li>
                  ))}
                </ul>
              )
            }
            <time datetime={updatedIso} class="font-mono text-xs text-sub"
              >updated: {updatedIso}</time
            >
          </div>
        </header>

        <div class="prose">
          <slot />
        </div>

        {
          /* モバイル: 使用辞書一覧を本文下部に（wikilink-ui R-17。逆リンクより上） */
        }
        <LinkedDictList
          dicts={linkedDicts}
          class="mt-12 border-t border-line pt-8 lg:hidden"
        />

        {
          /* 逆リンク（辞書・wikilink-ui R-18）= Backlinks / 前後章ナビ（pages R-16）の差込口 */
        }
        <slot name="below" />
      </article>

      {/* 右: 辞書ペイン + 使用辞書一覧（wikilink-ui R-17・ペイン下） */}
      <aside class="hidden lg:block">
        <div class="sticky top-24">
          <DictPane />
          <LinkedDictList dicts={linkedDicts} class="mt-8" />
        </div>
      </aside>
    </div>
  </main>

  {/* モバイル: フローティング目次ボタン + 目次ボトムシート */}
  <MobileNav headings={headings} />

  <script>
    import { initToc } from "../scripts/toc";
    import { initDictPane } from "../scripts/dict-pane";
    import { initDictPreview } from "../scripts/dict-preview";
    initToc();
    initDictPane();
    initDictPreview();
  </script>
</BaseLayout>
