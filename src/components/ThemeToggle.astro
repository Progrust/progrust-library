---
// テーマ切替ボタン（theme.md R-4 / ui-design-spec「テーマ切替」）。
// 太陽/月アイコンを dark:hidden / hidden dark:block で出し分ける。
// 切替ロジックは src/scripts/theme.ts（クライアント JS はコンポーネントに書かない規約 §4）。
---

<button
  type="button"
  data-theme-toggle
  aria-label="テーマを切り替える"
  class="grid h-9 w-9 place-items-center rounded border border-line bg-card text-sub transition-colors hover:border-accent hover:text-accent motion-reduce:transition-none"
>
  {/* 太陽（ライト時に表示） */}
  <svg
    class="h-4 w-4 dark:hidden"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path
      d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
    ></path>
  </svg>
  {/* 月（ダーク時に表示） */}
  <svg
    class="hidden h-4 w-4 dark:block"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<script>
  import { initThemeToggle } from "../scripts/theme";
  initThemeToggle();
</script>
