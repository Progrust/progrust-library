---
// 一覧の絞込 UI（ui-design-spec「タグチップ（絞込UI）」search R-9〜R-11 / AC-7）。
// キーワード入力 + 件数（N / 総数）+ タグチップ（出現件数降順・上位12個 + 超過分は展開式）。
// 動作（タグ AND 選択・キーワード部分一致・件数/0件更新）は src/scripts/list-filter.ts。
// data-* 属性を絞込 JS が参照する。JS 無効時は disabled の静的表示のまま（PE）。
interface Props {
  tags: Array<{ tag: string; count: number }>;
  total: number;
}

const { tags, total } = Astro.props;

const VISIBLE_TAGS = 12;
const hiddenCount = Math.max(0, tags.length - VISIBLE_TAGS);
---

<div
  class="mb-8 flex flex-col gap-4 border-b border-line pb-8"
  data-list-filter
  data-total={total}
>
  <div class="flex flex-wrap items-center gap-4">
    <label class="relative flex-1 sm:max-w-xs">
      <span
        class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-sub"
      >
        <svg
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m20 20-3.5-3.5"></path>
        </svg>
      </span>
      <input
        type="search"
        placeholder="キーワードで絞り込み"
        disabled
        aria-label="一覧内をキーワードで絞り込み"
        data-filter-keyword
        class="h-10 w-full rounded border border-line bg-card pl-9 pr-3 text-sm text-ink placeholder:text-sub focus:border-accent focus:outline-none"
      />
    </label>
    <p class="font-mono text-xs text-sub" data-filter-count>
      <span class="font-semibold text-strong" data-filter-hits>{total}</span> / {
        total
      } entries
    </p>
  </div>

  <p class="hidden text-sm text-sub" data-filter-empty>
    該当するエントリがありません。
  </p>

  {
    tags.length > 0 && (
      <div class="flex flex-wrap gap-2">
        {tags.map(({ tag, count }, i) => (
          <button
            type="button"
            disabled
            aria-pressed="false"
            data-filter-tag={tag}
            class:list={[
              "rounded border border-line bg-card px-2.5 py-1 font-mono text-[11px] text-sub transition-colors hover:border-accent hover:text-accent aria-pressed:border-accent aria-pressed:text-accent motion-reduce:transition-none",
              { hidden: i >= VISIBLE_TAGS },
            ]}
          >
            #{tag} <span class="text-sub">{count}</span>
          </button>
        ))}
        {hiddenCount > 0 && (
          <button
            type="button"
            disabled
            data-filter-more
            class="px-2.5 py-1 font-mono text-[11px] text-accent transition-colors hover:underline motion-reduce:transition-none"
          >
            + {hiddenCount} tags
          </button>
        )}
      </div>
    )
  }
</div>

<script>
  import { initListFilter } from "../scripts/list-filter";
  initListFilter();
</script>
