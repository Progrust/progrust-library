---
// 記事・本一覧の横並びカード（pages R-9/R-10。ユーザー確定: 画像左・横並び）。
// 左にヘッダ画像、右に 日付 / タイトル / 概要（description）/ タグ。
// data-title / data-tags は P5 の絞込 JS 用の予約属性（data-tags は | 区切り）。
// 画像はダミーの remote URL を文字列で受ける（画像最適化は後続タスク。content.config.ts 参照）。
interface Props {
  href: string;
  title: string;
  description: string;
  createdAt: Date;
  tags: string[];
  image: { url: string; alt: string };
}

const { href, title, description, createdAt, tags, image } = Astro.props;
const isoDate = createdAt.toISOString().slice(0, 10);
---

<a
  href={href}
  data-title={title}
  data-tags={tags.join("|")}
  class="group flex flex-col gap-4 rounded border border-line bg-card p-4 transition-colors hover:border-accent motion-reduce:transition-none sm:flex-row sm:gap-5 sm:p-5"
>
  <img
    src={image.url}
    alt={image.alt}
    loading="lazy"
    class="aspect-[1200/630] w-full shrink-0 rounded border border-line/70 object-cover sm:w-40"
  />
  <div class="flex min-w-0 flex-col gap-2">
    <time datetime={isoDate} class="font-mono text-xs text-sub">{isoDate}</time>
    <span class="font-display font-bold text-strong group-hover:text-accent"
      >{title}</span
    >
    <p class="line-clamp-2 text-sm leading-relaxed text-sub">{description}</p>
    {
      tags.length > 0 && (
        <span class="flex flex-wrap gap-2 font-mono text-[11px] text-sub">
          {tags.map((tag) => (
            <span>#{tag}</span>
          ))}
        </span>
      )
    }
  </div>
</a>
