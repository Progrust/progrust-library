---
// 全ページ共通ヘッダー（スクロール固定。pages.md R-2 / ui-design-spec「ヘッダー」）。
// ロゴ + 検索ボックス（見た目のみ）+ テーマ切替の 3 点のみ。ナビリンクは置かない。
import SearchBox from "./SearchBox.astro";
import ThemeToggle from "./ThemeToggle.astro";
---

<header
  class="sticky top-0 z-30 border-b border-line/70 bg-paper/95 backdrop-blur"
>
  <div class="mx-auto flex h-14 max-w-6xl items-center gap-6 px-4 sm:px-8">
    <a
      href="/"
      class="shrink-0 font-display text-lg font-bold text-strong transition-colors hover:text-accent motion-reduce:transition-none"
    >
      Progrust Library<span class="text-accent">.</span>
    </a>
    <SearchBox />
    <ThemeToggle />
  </div>
</header>
