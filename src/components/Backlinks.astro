---
// 逆リンク（wikilink-ui R-18 / R-19 / AC-7）。辞書詳細ページの本文下に、その辞書を
// wikilink でリンクしている公開コンテンツ（辞書・記事・章）を台帳リスト行
// （ui-design-spec「台帳リスト行（新着・逆リンク）」）で一覧表示する。
// データは src/lib/wikilink-graph.ts の backward マップ（辞書ページの getStaticPaths で構築。
// 非公開ソースの除外は getPublic* が担保）。DetailLayout の slot="below" に差し込む前提で
// 上罫線セクションとして本文の下に置く。章は「本タイトル › 章タイトル」で併記する。
import type { WikilinkRef } from "../lib/wikilink-graph";
import KindBadge from "./KindBadge.astro";

interface Props {
  items: WikilinkRef[];
  /** 配置調整用の追加クラス */
  class?: string;
}

const { items, class: className = "" } = Astro.props;
---

{
  items.length > 0 && (
    <section
      class={`mt-12 border-t border-line pt-8 ${className}`}
      aria-label="逆リンク"
    >
      <div class="mb-5 flex items-baseline justify-between">
        <h2 class="font-display text-xl font-black tracking-tight text-strong">
          この辞書が使われているページ
        </h2>
        <p class="font-mono text-[11px] text-sub">backlinks {items.length}</p>
      </div>
      <ol class="border-t border-line">
        {items.map((item) => (
          <li>
            <a
              href={item.href}
              class="group grid grid-cols-[auto_1fr] items-center gap-x-4 border-b border-line py-3.5 transition hover:bg-card motion-reduce:transition-none"
            >
              <KindBadge
                kind={item.kind}
                class="w-[4.5rem] shrink-0 justify-self-start text-center"
              />
              <span class="min-w-0 truncate font-display text-sm font-bold text-strong transition-colors group-hover:text-accent motion-reduce:transition-none">
                {item.bookTitle
                  ? `${item.bookTitle} › ${item.title}`
                  : item.title}
              </span>
            </a>
          </li>
        ))}
      </ol>
    </section>
  )
}
